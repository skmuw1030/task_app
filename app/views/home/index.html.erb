<% if user_signed_in? %>
<div class="bg-[#FAFAF9] p-6 min-h-screen">

  <div class="flex justify-between items-center mb-4">
      <h2 class="text-2xl font-bold text-slate-700">My Task Board</h2>
      <%= link_to new_task_path,
        class: "bg-teal-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-teal-600" do %>
        <i class="fa-solid fa-plus mr-1"></i>タスク作成
      <% end %>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl px-4 py-3 mb-5 flex items-center gap-3 flex-wrap">
    <p class="text-sm font-medium text-gray-600">
      <i class="fa-regular fa-clock mr-1"></i>スキマ時間に何する？
    </p>
    <div class="flex gap-2 flex-wrap">
      <% Task::SUKIMA_TIMES.each do |min| %>
        <%= link_to "#{min}分", root_path(sukima: min),
            class: "text-xs px-3 py-1 rounded-full border
              #{params[:sukima].to_i == min ?
                "bg-teal-500 text-white border-teal-500" : "bg-white text-gray-500 border-gray-200 hover:border-teal-300"}" %>
      <% end %>
      <% if params[:sukima].present? %>
        <%= link_to "クリア", root_path,
            class: "text-xs px-3 py-1 rounded-full bg-gray-100 text-gray-400 hover:bg-gray-200" %>
      <% end %>
    </div>
  </div>

  <div class="flex flex-row items-start gap-6 overflow-x-auto pb-4">

    <div class="flex-1 min-w-[300px] bg-[#F5F3FF] rounded-2xl shadow-sm p-4">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-purple-900">
        未着手
        <span class="bg-[#DDD6FE] text-xs px-2 py-1 rounded-full">
          <%= @todo_tasks.count %>件
        </span>
      </h3>
       <%= link_to new_task_path(status: "未着手"),
          class: "block items-center text-xs py-2 px-3 bg-purple-200 text-purple-500 rounded-xl hover:bg-purple-300" do %>
        <i class="fa-solid fa-plus mr-1"></i>タスクを追加
        <% end %>
    </div>
      <% @todo_tasks.each do |task| %>
        <%= render "task_card", task: task %>
      <% end %>
    </div>

    
    <div class="flex-1 min-w-[300px] bg-[#EFF6FF] rounded-2xl shadow-sm p-4">
      <div class="flex justify-between items-center mb-4">
      <h3 class="text-blue-900">
        進行中
        <span class="bg-[#BFDBFE] text-xs px-2 py-1 rounded-full">
          <%= @doing_tasks.count %>件
        </span>
      </h3>
      <%= link_to new_task_path(status: "進行中"),
          class: "block items-center text-xs py-2 px-3 bg-blue-200 text-blue-500 rounded-xl hover:bg-blue-300" do %>
        <i class="fa-solid fa-plus mr-1"></i>タスクを追加
      <% end %>
      </div>
      <% @doing_tasks.each do |task| %>
        <%= render "task_card", task: task %>
      <% end %>
    </div>


    <div class="flex-1 min-w-[300px] bg-[#E6FFFA] rounded-2xl shadow-sm p-4">
      <h3 class="mb-4 text-teal-900 flex items-center gap-1">
        完了
        <span class="bg-[#99F6E4] text-xs px-2 py-1 rounded-full">
          <%= @done_tasks.count %>件
        </span>
      </h3>
      <% @done_tasks.each do |task| %>
        <%= render "task_card", task: task %>
      <% end %>
    </div>

  </div>
</div>

<% else %>
  <div class="bg-teal-50/30 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-xl px-6">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">タスクは付箋からカンバンボードへ</h1>
      <p class="text-gray-500 mb-8">スキマ時間を有効活用できるようタスクを抽出できるようにしました</p>
      <div class="flex flex-col gap-3 max-w-xs mx-auto">
        <%= link_to "新規登録", new_user_registration_path,
            class: "block bg-teal-500 text-white py-3 rounded-lg hover:bg-teal-600 font-medium" %>
        <%= link_to "ログイン", new_user_session_path,
            class: "block border border-teal-500 text-teal-600 py-3 rounded-lg hover:bg-teal-50 font-medium" %>
        <%= button_to "ゲストログイン", guest_sign_in_path,
            method: :post,
            class: "block w-full bg-gray-100 text-gray-700 py-3 rounded-lg hover:bg-gray-200 font-medium" %>
      </div>
    </div>
  </div>
<% end %>