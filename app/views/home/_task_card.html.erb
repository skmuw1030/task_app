<%
  priority_config = case task.priority
                    when "高"
                      { class: "bg-red-50 text-red-700 border-red-100", label: "高" }
                    when "中"
                      { class: "bg-yellow-50 text-yellow-700 border-yellow-100", label: "中" }
                    else
                      { class: "bg-green-50 text-green-700 border-green-100", label: "低" }
                    end
  color_code_due = case task.due_status
                    when :overdue then "text-red-500 font-medium"
                    when :urgent then "text-yellow-500"
                    else ""
                    end
%>

<div class="bg-white rounded-2xl shadow-sm 
  <%= task.fit_in_time?(params[:sukima])? "ring-2 ring-teal-300" : "" %> 
p-3 mb-3">

  <div class="flex flex-wrap gap-1 mb-2">
    <% if task.overdue? %>
      <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">
        <i class="fa-solid fa-circle-xmark mr-1"></i>期限切れ
      </span>
    <% elsif task.urgent? %>
      <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">
        <i class="fa-solid fa-triangle-exclamation mr-1"></i> 残り<%= task.days_left %>日
      </span>
    <% end %>
    <% if task.has_missing_docs? %>
      <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">
        <i class="fa-regular fa-note-sticky mr-1"></i>不足書類</span>
    <% end %>
    <span class="text-xs <%= priority_config[:class] %> px-2 py-0.5 rounded-full" >
      <%= priority_config[:label] %>
    </span>
    <% if task.fit_in_time?(params[:sukima]) %>
      <span class="text-xs bg-teal-100 text-teal-700 px-2 py-0.5 rounded-full">
        <i class="fa-solid fa-mug-hot mr-1"></i>スキマでできる
      </span>
    <% end %>
  </div>

  <p class="text-sm font-medium text-gray-800 mb-1"><%= task.title %></p>

  <div class="text-xs text-gray-500 space-y-0.5 mb-2">
    <p class="flex items-center">
      <i class="fa-solid fa-user mr-1"></i><%= task.creator.name %> より依頼
    </p>
    <% if task.due_date %>
      <p class="text-xs <%= color_code_due %>">
        <i class="fa-regular fa-calendar mr-1"></i>
        <%= task.due_date.strftime("%m/%d") %>
      </p>
    <% end %>
    <% if task.estimated_minutes %>
      <p class="flex items-center"><i class="fa-regular fa-clock mr-1"></i><%= task.estimated_minutes %>分</p>
    <% end %>
  </div>
  
  <div class="flex items-center gap-2 mt-2 flex-wrap">
    <%= link_to "詳細", task_path(task), class: "text-xs text-blue-400 hover:underline" %>
    <%= link_to "編集", edit_task_path(task), class: "text-xs text-gray-400 hover:underline" %>
    <% if task.status != "完了" %>
      <% if task.completable? %>
        <%= button_to task_path(task, task: { status: "完了" }),
            method: :patch,
            class: "text-xs bg-teal-400 text-white px-2 py-0.5 rounded-lg hover:bg-teal-500" do %>
              <i class="fa-solid fa-circle-check mr-1"></i>完了
        <% end %>
      <% else %>
        <span class="text-xs text-gray-300">
          <i class="fa-solid fa-spinner mr-1"></i>子タスク待ち
        </span>
      <% end %>
    <% end %>
  </div>

</div>