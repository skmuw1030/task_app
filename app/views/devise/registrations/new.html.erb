<div class="bg-teal-50 flex min-h-screen items-center justify-center pb-14">
  <div class="bg-white p-7 rounded-lg shadow-lg w-full max-w-md">
    <h2 class="text-center mb-10 font-bold text-lg text-slate-800">新規登録</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      
      <div class="mb-6 w-full">
        <%= f.label :name, "お名前(フルネーム)", class: "block w-[85%] mx-auto mb-2 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "例：山田 太郎" ,
            class: "block w-[85%] mx-auto p-3 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>

        <% if resource.errors.has_key?(:name) %>
          <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600"><%= resource.errors.full_messages_for(:name).first %></span>
        <% end %>
      </div>

      <div class="mb-6 w-full">
        <%= f.label :email, class: "block w-[85%] mx-auto mb-2 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.email_field :email, autocomplete: "email", 
            class: "block w-[85%] mx-auto p-3 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>

        <% if resource.errors.has_key?(:email) %>
          <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
            <%= resource.errors.full_messages_for(:email).first %>
          </span>
        <% end %>
      </div>

      <div class="mb-6 w-full">
        <%= f.label :password, class: "block w-[85%] mx-auto mb-2 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.password_field :password, autocomplete: "new-password", 
            class: "block w-[85%] mx-auto p-3 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>

        <% if resource.errors.has_key?(:password) %>
          <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
            <%= resource.errors.full_messages_for(:password).first %>
          </span>
        <% elsif @minimum_password_length %>
          <small class="block w-[85%] mx-auto text-left mt-1 text-xs text-gray-600"><%= @minimum_password_length %>文字以上、英数字含む</small>
        <% end %>
      </div>

      <div class="mb-6 w-full">
        <%= f.label :password_confirmation, class: "block w-[85%] mx-auto mb-2 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", 
            class: "block w-[85%] mx-auto p-3 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>

        <% if resource.errors.has_key?(:password_confirmation) %>
          <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
            <%= resource.errors.full_messages_for(:password_confirmation).first %>
          </span>
        <% end %>
      </div>

      <div class="flex justify-center w-full mt-8">
        <%= f.submit "アカウントを登録", class: "w-[85%] p-3.5 rounded-lg bg-teal-500 text-white font-bold border-none text-base shadow-md hover:bg-teal-400" %>
      </div>
    <% end %>

    <div class="mt-5 text-center text-gray-600 text-sm">
      すでにアカウントをお持ちの方は 
      <%= link_to "ログイン", new_user_session_path, class: "text-teal-500 font-bold ml-0.5 hover:underline " %>
    </div>
  </div>
</div>

