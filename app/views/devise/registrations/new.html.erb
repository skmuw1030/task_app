<div class="auth-wrapper">
  <div class="auth-card">
    <h2 class="auth-title">新規登録</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      
      <div class="field">
        <%= f.label :name, "お名前(フルネーム)", class: "field-label" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "例：山田 太郎" ,class: "input-field" %>

        <% if resource.errors.has_key?(:name) %>
          <span class="error-text"><%= resource.errors.full_messages_for(:name).first %></span>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :email, class: "field-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "input-field" %>

        <% if resource.errors.has_key?(:email) %>
          <span class="error-text">
            <%= resource.errors.full_messages_for(:email).first %>
          </span>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password, class: "field-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "input-field" %>

        <% if resource.errors.has_key?(:password) %>
          <span class="error-text">
            <%= resource.errors.full_messages_for(:password).first %>
          </span>
        <% elsif @minimum_password_length %>
          <small class="field-hint"><%= @minimum_password_length %>文字以上、英数字含む</small>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, class: "field-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-field" %>

        <% if resource.errors.has_key?(:password_confirmation) %>
          <span class="error-text">
            <%= resource.errors.full_messages_for(:password_confirmation).first %>
          </span>
        <% end %>
      </div>

      <div class="actions">
        <%= f.submit "アカウントを登録", class: "submit-btn" %>
      </div>
    <% end %>

    <div class="auth-footer">
      すでにアカウントをお持ちの方は 
      <%= link_to "ログイン", new_user_session_path, class: "submit-link" %>
    </div>
  </div>
</div>

