<div class="bg-teal-50 flex min-h-screen justify-center items-center pb-12">
  <div class="bg-white p-4 rounded-lg shadow-lg w-full max-w-md my-auto">
    <h2 class="text-center mb-4 font-bold text-lg text-slate-800">アカウント編集</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

      <div class=" mb-4 w-full">
        <%= f.label :name, "お名前(フルネーム)", class: "block w-[85%] mx-auto mb-1 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "例：山田 太郎" ,
            class: "block w-[85%] mx-auto p-2 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>
          <% if resource.errors.has_key?(:name) %>
            <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
              <%= resource.errors.full_messages_for(:name).first %>
            </span>
          <% end %>
      </div>

      <div class="mb-4 w-full">
        <%= f.label :email ,class: "block w-[85%] mx-auto mb-1 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.email_field :email, autocomplete: "email", 
            class: "block w-[85%] mx-auto p-2 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>
          <% if resource.errors.has_key?(:email) %>
            <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
              <%= resource.errors.full_messages_for(:email).first %>
            </span>
          <% end %>
      </div>

      <div class="mb-4 w-full">
        <%= f.label :password, class: "block w-[85%] mx-auto mb-1 font-semibold text-left text-slate-600 text-sm" %> 
        <%= f.password_field :password, autocomplete: "new-password", 
            class: "block w-[85%] mx-auto p-2 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>
          <% if resource.errors.has_key?(:password) %>
            <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
              <%= resource.errors.full_messages_for(:password).first %>
            </span>
          <% elsif @minimum_password_length %>
            <small class="block w-[85%] mx-auto text-left mt-1 text-xs text-gray-600">
              ※変更する場合のみ入力。<%= @minimum_password_length %>文字以上、英数字含む
            </small>
          <% end %>
      </div>

      <div class="mb-4 w-full">
        <%= f.label :password_confirmation, class: "block w-[85%] mx-auto mb-1 font-semibold text-left text-slate-600 text-sm" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", 
            class: "block w-[85%] mx-auto p-2 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md"%>
          <% if resource.errors.has_key?(:password_confirmation) %>
            <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
              <%= resource.errors.full_messages_for(:password_confirmation).first %>
            </span>
          <% end %>
      </div>

      <div class="mb-4 w-full">
        <%= f.label :current_password, class: "block w-[85%] mx-auto mb-1 font-semibold text-left text-slate-600 text-sm" %> 
        <%= f.password_field :current_password, autocomplete: "current-password", class: "block w-[85%] mx-auto p-2 rounded-lg text-base border border-slate-200 outline-none focus:border-green-600 focus:shadow-md" %>
        <p class="w-[85%] mx-auto text-xs text-gray-600 mt-1">※変更を保存するには現在のパスワードが必要です</p>
          <% if resource.errors.has_key?(:current_password) %>
            <span class="block w-[85%] mx-auto text-left mt-1 text-xs font-semibold text-red-600">
              <%= resource.errors.full_messages_for(:current_password).first %>
            </span>
          <% end %>
      </div>

      <div class="flex justify-center w-full mt-5">
        <%= f.submit "更新する", class: "w-[85%] p-3 rounded-lg bg-teal-500 text-white font-bold border-none text-base shadow-md hover:bg-teal-400" %>
      </div>
    <% end %>

    <div class="mt-4 pt-3 border-t border-slate-100">
      <div class="flex items-center justify-between px-4">
        <%= link_to :back, class: "flex items-center text-sm text-slate-500 hover:text-slate-600" do %>
          <i class="fa-solid fa-arrow-left mr-1"></i>戻る
        <% end %>
      
      <div class="flex items-center">
        <button type="button" onclick="openModal()" class="text-sm font-medium text-red-400 hover:underline ">
          <i class="fa-solid fa-trash mr-1"></i>アカウント削除
        </button>
      </div>
    </div>
  </div>

  <%# 削除モーダル %>
  <div id="delete-modal" class="fixed z-50 hidden flex items-center justify-center  bg-black/50 inset-0 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-xl max-w-sm w-full  mx-4 overflow-hidden">
    
      <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
        <h5 class="font-bold text-red-600 text-base">退会確認</h5>
        <button type="button" onclick="closeModal()" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
      </div>

     <%= form_for(resource, as: resource_name, url: registration_path(resource_name), method: :delete) do |f| %>
      <div class="px-7 py-5 text-center">
        <p class="text-slate-700 font-medium">アカウントを本当に削除しますか？</p>
        <p class="text-xs text-slate-400 mt-2">※削除するには現在のパスワード入力が必要です</p>
      </div>

    
        <div class="px-7 py-5 mb-3 text-center">
          <%= f.password_field :current_password, placeholder: "現在のパスワード",
              class: "w-full p-2 rounded-lg text-sm border border-slate-100 outline-none focus:border-red-400" %>

          <% if resource.errors[:current_password].any? %>
            <p class="text-xs text-red-500 mt-1 ml-1 text-left">
              <%= resource.errors.full_messages_for(:current_password).first %>
            </p>
          <% end %>
        </div>

      <div class="px-6 py-4 bg-slate-50 flex gap-3 justify-end">
        <button type="button" onclick="closeModal()" class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-800">
          キャンセル
        </button>
      
        <%= f.submit "削除する",
            class: "px-4 py-2 bg-red-500 text-white text-sm font-bold rounded-lg hover:bg-red-600" %>
      </div>
      <% end %>
    
    </div>
  </div>

  <script>
    function openModal() {
      document.getElementById('delete-modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('delete-modal').classList.add('hidden');
    }

    <% if resource.errors[:current_password].any? %>
      openModal();
    <% end %>
  </script>
</div>