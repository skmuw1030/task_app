<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-temporary
        class="w-[85%] mx-auto box-border bg-red-50 p-2.5 rounded-lg border border-red-200 mb-5 text-left">
    <h2 class="sr-only">
      <%= I18n.t("errors.messages.not_saved",
                 count: resource.errors.count,
                 resource: resource.class.model_name.human.downcase)
       %>
    </h2>
    
    <ul class="list-disc m-0 pl-5 text-red-700 text-sm">
      <% resource.errors.full_messages.each do |message| %>
        <li class="mb-1"><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
