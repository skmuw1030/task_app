<%
  sub_priority_config = case @sub_task.priority
                        when "高"
                          { class: "bg-red-50 text-red-700 border-red-100", label: "高" }
                        when "中"
                          { class: "bg-yellow-50 text-yellow-700 border-yellow-100", label: "中" }
                        else
                          { class: "bg-green-50 text-green-700 border-green-100", label: "低" }
                        end
  sub_color_code_due = case @sub_task.due_status
                        when :overdue then "text-red-500 font-medium"
                        when :urgent then "text-yellow-500"
                        else ""
                        end
  sub_status_config = case @sub_task.status
                        when "未着手"
                          { class: "bg-[#DDD6FE] text-purple-900 border-purple-100", label: "未着手"}
                        when "進行中"
                          { class: "bg-[#BFDBFE] text-blue-900 border-blue-100", label: "進行中"}
                        else
                          { class: "bg-[#99F6E4] text-teal-900 border-teal-100", label: "完了"}
                        end
%>


<div class="bg-[#FAFAF9] min-h-screen">
  <div class="max-w-2xl mx-auto px-5 py-6">

    <div class="flex items-center gap-2 text-xs text-gray-500 mb-4">
      <%= link_to "ボード", root_path, class: "hover:underline" %>
      <span>/</span>
      <%= link_to @task.title, task_path(@task), class: "hover:underline hover:text-teal-600" %>
      <span>/</span>
      <span class="text-sm font-medium text-gray-700"><%= @sub_task.title %></span>
    </div>

    <div class="bg-white border border-gray-200 shadow-sm rounded-xl mb-6">
      <div class="px-5 py-4 border-b border-gray-100 flex justify-between items-center">
        <div class="flex items-center gap-2">
          <span class="text-xs font-bold text-rose-400 border border-rose-200 px-1.5 py-1 rounded">子タスク</span>
          <h1 class="text-lg font-semibold text-gray-900"><%= @sub_task.title %></h1>
        </div>
        <%= link_to "編集", edit_task_sub_task_path(@task, @sub_task),
            class: "px-3 py-1.5 text-xs text-gray-500 border border-gray-200 rounded-lg hover:bg-gray-50" %>
      </div>

      <div class="px-5 py-4 space-y-6">
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-xs text-gray-400 mb-1">担当者</p>
            <p class="text-gray-800"><%= @sub_task.assignee.name %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">依頼者</p>
            <p class="text-gray-800"><%= @sub_task.creator.name %></p>
          </div>
          <div>
            <% if @sub_task.due_date %>
              <p class="text-xs text-gray-400 mb-1">期限日</p>
              <p class="text-sm font-medium <%= sub_color_code_due %>">
                <%= @sub_task.due_date&.strftime("%m/%d") || "—" %>
              </p>
            <% end %>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">依頼日</p>
            <p><%= @sub_task.created_at.strftime("%m/%d") %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">目安時間</p>
            <p class="text-gray-800"><%= @sub_task.estimated_minutes ? "#{@sub_task.estimated_minutes}分" : "—" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">優先度</p>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold border <%= sub_priority_config[:class] %>">
              <%= sub_priority_config[:label] %>
            </span>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">着手日</p>
            <p><%= @sub_task.started_at&.strftime("%m/%d") || "未着手" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">完了日</p>
            <p><%= @sub_task.completed_at&.strftime("%m/%d") || "—" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">ステータス</p>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold border <%= sub_status_config[:class] %>">
              <%= sub_status_config[:label] %>
            </span>
          </div>
        </div>
        <% if @sub_task.note.present? %>
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="text-xs text-gray-400 mb-2">備考欄</p>
            <p class="text-sm text-gray-700"><%= @sub_task.note %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%
      priority_config = case @task.priority
                        when "高"
                          { class: "bg-red-50 text-red-700 border-red-100", label: "高" }
                        when "中"
                          { class: "bg-yellow-50 text-yellow-700 border-yellow-100", label: "中" }
                        else
                          { class: "bg-green-50 text-green-700 border-green-100", label: "低" }
                        end
      status_config = case @task.status
                        when "未着手"
                          { class: "bg-[#DDD6FE] text-purple-900 border-purple-100", label:"未着手" }
                        when "進行中"
                          { class: "bg-[#BFDBFE] text-blue-900 border-blue-100", label:"進行中" }
                        else 
                          { class: "bg-[#99F6E4] text-teal-900 border-teal-100", label:"完了" }
                        end
      color_code_due = case @task.due_status
                        when :overdue then "text-red-500 font-medium"
                        when :urgent then "text-yellow-500"
                        else ""
                        end
    %>

    <div class="bg-white border border-gray-200 shadow-sm rounded-xl">

      <div class="px-5 py-4 border-b border-gray-100 flex justify-between items-center">
        <div class="flex items-center gap-2">
          <span class="text-xs font-bold text-teal-400 border border-teal-200 px-1.5 py-1 rounded">親タスク</span>
          <h1 class="text-lg font-semibold text-gray-900"><%= @task.title %></h1>
        </div>
        <% if @task.creator == current_user || @task.assignee == current_user || current_user.admin? || current_user.guest? %>
          <%= link_to "編集", edit_task_path(@task),
              class: "px-3 py-1.5 text-xs text-gray-500 border border-gray-200 rounded-lg hover:bg-gray-50" %>
        <% end %>
      </div>

      <div class="px-5 py-4 space-y-4">
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-xs text-gray-400 mb-1">担当者</p>
            <p class="text-gray-800"><%= @task.assignee.name %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">依頼者</p>
            <p class="text-gray-800"><%= @task.creator.name %></p>
          </div>
          <div>
            <% if @task.due_date %>
              <p class="text-xs text-gray-400 mb-1">期限日</p>
              <p class="text-sm font-medium <%= color_code_due %>">
                <%= @task.due_date&.strftime("%m/%d") || "—" %>
              </p>
            <% end %>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">依頼日</p>
            <p><%= @task.assigned_date&.strftime("%m/%d") || "—" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">目安時間</p>
            <p><%= @task.estimated_minutes ? "#{@task.estimated_minutes}分" : "—" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">優先度</p>
            <p class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold border <%= priority_config[:class] %>">
              <%= priority_config[:label] %>
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">着手日</p>
            <p><%= @task.started_at&.strftime("%m/%d") || "未着手" %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-1">完了日</p>
            <p><%= @task.completed_at&.strftime("%m/%d") || "—" %></p>
          </div>
        </div>
        <div>
          <p class="text-xs text-gray-400 mb-1">ステータス</p>
          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold border <%= status_config[:class] %>">
            <%= status_config[:label] %>
          </span>
        </div>

        <% if @task.comment.present? %>
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="text-xs text-gray-400 mb-2">備考欄</p>
            <p class="text-sm text-gray-700"><%= @task.comment %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
