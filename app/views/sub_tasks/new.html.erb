<div class="bg-[#FAFAF9] min-h-screen">
  <div class="mx-auto max-w-lg px-5 py-3">

    <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
      <%= link_to "ボード", root_path, class: "text-gray-500 hover:underline" %>
      <span>/</span>
      <%= link_to @task.title, task_path(@task), class: "hover:underline text-gray-500" %>
      <span>/</span>
      <span class="text-gray-700">依頼タスクを追加</span>
    </div>

    <div class="bg-white border border-gray-200 shadow-sm rounded-xl">
      <div class="px-5 py-4 border-b border-gray-100">
        <h1 class="text-center text-base font-medium text-gray-800">依頼タスクを追加</h1>
        <p class="text-right text-xs text-gray-400 mt-1">親タスク：<%= @task.title %></p>
      </div>

      <div class="px-5 py-5">
        <%= render "form", sub_task: @sub_task, task: @task %>
      </div>
    </div>

  </div>
</div>