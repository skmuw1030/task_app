<% 
  is_new = sub_task.new_record?
  is_creator = is_new || (sub_task.creator == current_user)
  is_assignee = sub_task.assignee == current_user
%>

<%= form_with model: [task, sub_task], data: { turbo_frame: "_top" } do |f| %>

  <div class="mb-4">
    <%= f.label :title, "タスク名", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, readonly: !is_creator,
        placeholder: "例：ケアマネ 佐藤さんへFAX送付",
        class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 focus:outline-none focus:border-teal-400" %>
    <% if sub_task.errors[:title].any? %>
      <p class="text-xs text-red-600">
        <%= sub_task.errors.full_messages_for(:title).first %>
      </p>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :assignee_id, "担当者", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <% if is_creator %>
      <%= f.collection_select :assignee_id,
          User.order(:name), :id, :name,
          { include_blank: "担当者を選択" }, { class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-500 focus:text-gray-800 focus:outline-none focus:border-teal-400" } %>
    <% else %>
      <div class="w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500 cursor-not-allowed">
        <%= sub_task.assignee&.name || "未設定" %>
      </div>
      <%= f.hidden_field :assignee_id %>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :due_date, "期限日", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.date_field :due_date, readonly: !is_creator,
        class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-500 focus:text-gray-800 focus:outline-none focus:border-teal-400" %>
  </div>

  <div class="mb-4">
    <%= f.label :priority, "優先度", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <% if is_creator %>
      <%= f.select :priority,
          Task::PRIORITIES,
          {},
          class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 focus:outline-none focus:border-teal-400" %>
    <% else %>
      <div class="w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500 cursor-not-allowed">
        <%= sub_task.priority %>
      </div>
      <%= f.hidden_field :priority %>
    <% end %>
    <% if sub_task.errors[:priority].any? %>
      <p class="text-xs text-red-600">
        <%= sub_task.errors.full_messages_for(:priority).first %>
      </p>
    <% end %>  
  </div>

  <div class="mb-4">
    <%= f.label :estimated_minutes, "目安時間（分）", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.number_field :estimated_minutes,
        min: 0, step:5, readonly: !(is_creator || is_assignee),
        placeholder: "例：15 （5分単位)",
        class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 focus:outline-none focus:border-teal-400" %>
    <% if sub_task.errors[:estimated_minutes].any? %>
      <p class="text-xs text-red-600">
        <%= sub_task.errors.full_messages_for(:estimated_minutes).first %>
      </p>
    <% end %>
  </div>

  <% unless is_new %>
    <div class="mb-4">
      <%= f.label :status, "ステータス", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <% if is_creator || is_assignee %>
        <%= f.select :status,
            Task::STATUSES,
            {},
            class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 focus:outline-none focus:border-teal-400" %>
      <% else %>
        <div class="w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-400 cursor-not-allowed">
          <%= sub_task.status %>
        </div>
        <%= f.hidden_field :status %>
      <% end %>
      <% if sub_task.errors[:status].any? %>
        <p class="text-xs text-red-600">
          <%= sub_task.errors.full_messages_for(:status).first %>
        </p>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :note, "メモ", class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_area :note,
        rows: 3,
        placeholder: "補足情報など",
        class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 focus:outline-none focus:border-teal-400" %>
    <% if sub_task.errors[:note].any? %>
      <p class="text-xs text-red-600">
        <%= sub_task.errors.full_messages_for(:note).first %>
      </p>
    <% end %>
  </div>

  <div class="flex gap-3 pt-1">
    <%= f.submit sub_task.persisted? ? "更新する" : "追加する",
        class: "flex-1 bg-rose-400 text-white py-2.5 rounded-xl text-sm font-medium hover:bg-rose-500 " %>
    <%= link_to "キャンセル", root_path,
        data: { turbo_frame: "_top" },
        class: "flex-1 text-center border border-gray-200 text-gray-500 py-2.5 rounded-xl text-sm hover:bg-gray-50" %>
  </div>

<% end %>