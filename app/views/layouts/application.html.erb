<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Task App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% unless devise_controller? %>
      <div class="flash-messages">
        <% flash.each do |type, message| %>
          <div class="flash-item <%= type %>"><%= message %></div>
        <% end %>
      </div>
    <% end %>

    <header class="bg-white flex items-center h-15 border-b border-gray-100 ">
      <div class="w-full mx-auto px-5 flex justify-between items-center ">
        <%= link_to "TaskApp", root_path, class: "text-2xl font-bold text-teal-500" %>

        <nav class="header-nav">
          <% if user_signed_in? %>
            <div class="relative group">
              <button class="bg-none border-none py-2 px-3 flex items-center text-base text-gray-800">
                <i class="fa-solid fa-circle-user mr-2 text-teal-500 text-xl"></i><span><%= current_user.name %></span> さん
                <i class="fa-solid fa-chevron-down ml-1.5 text-xs text-gray-600"></i>
              </button>
          
              <div class="hidden absolute  group-hover:block right-0 top-full bg-white shadow-lg rounded-lg border border-gray-300 overflow-hidden z-50">
                <% if current_user.admin? || current_user.guest? %>
                  <%= link_to admin_tasks_path, class: "block w-full py-3 px-4 text-sm text-left border-none bg-none text-gray-600 hover:bg-teal-50 hover:text-teal-500 whitespace-nowrap" do %>
                    <i class="fa-solid fa-bars-progress mr-1"></i>タスク進捗
                  <% end %>
                <% end %>
                <%= link_to "作成したタスク一覧", created_tasks_path, class: "block w-full py-3 px-4 text-sm text-left border-none bg-none text-gray-600 hover:bg-teal-50 hover:text-teal-500 whitespace-nowrap" %>
                <%= link_to "アカウント設定", edit_user_registration_path, class: "block w-full py-3 px-4 text-sm text-left border-none bg-none text-gray-600 hover:bg-teal-50 hover:text-teal-500" %>
                <hr class="border-0 m-0 border-t border-slate-100">
                <button type="button" onclick="openLogoutModal()" class="block w-full py-3 px-4 text-sm text-left border-none bg-none  text-red-600 hover:bg-red-50 hover:text-red-700" >
                  ログアウト
                </button>
              </div>
            </div>
          <% else %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <%= yield %>
    </main>

    <%= turbo_frame_tag "modal" %>

    <div id="logout-modal" class="fixed z-[100] hidden flex items-center justify-center  bg-black/50 inset-0 backdrop-blur-sm">
      <div class="bg-white rounded-xl shadow-xl max-w-sm w-full  mx-4 overflow-hidden">
    
        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
          <h5 class="font-bold text-gray-800 text-base">ログアウト確認</h5>
          <button type="button" onclick="closeLogoutModal()" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
        </div>

        <div class="px-7 py-5 text-center">
          <p class="text-slate-700 font-medium">ログアウトしてもよろしいですか？</p>
        </div>

        <div class="px-6 py-4 bg-slate-50 flex gap-3 justify-end">
          <button type="button" onclick="closeLogoutModal()" class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-800">
            キャンセル
          </button>
      
          <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
              class: "px-5 py-2 bg-teal-500 text-white text-sm font-bold rounded-lg hover:bg-teal-600" %>
        </div>
    
      </div>
    </div>
    <script>
      function openLogoutModal() {
        document.getElementById('logout-modal').classList.remove('hidden');
      }
      function closeLogoutModal() {
        document.getElementById('logout-modal').classList.add('hidden');
      }
    </script>

  </body>
</html>
