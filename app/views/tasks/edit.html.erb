<div class="bg-[#FAFAF9] min-h-screen">
  <div class="mx-auto max-w-5xl px-5 py-3"  >

  <div class="flex items-center gap-2 text-xs text-gray-400 mb-4">
      <%= link_to "ボード", root_path, class: "text-gray-500 hover:underline" %>
      <span>/</span>
      <span class="text-gray-700 font-medium">タスクを編集</span>
    </div>

    <div class="bg-white border border-gray-200 shadow-sm rounded-xl">
      <div class="px-5 py-4 border-b border-gray-100">
        <h1 class="text-center text-lg font-semibold text-gray-800">
        <i class="fa-solid fa-pen-to-square"></i>
          タスクを編集
        </h1>
      </div>

      <div class="px-5 py-5">
        <%= render "form", task: @task %>
      </div>
    </div>

  </div>
</div>